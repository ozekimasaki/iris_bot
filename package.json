{
  "name": "iris-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Iris is a reusable Discord operations bot for multi-guild deployments.",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --noEmit --project tsconfig.json",
    "start": "bun run src/index.ts",
    "test": "bun run src/test/smoke.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "commands:sync": "bun run src/app/command-sync.ts"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.2",
    "luxon": "^3.7.1",
    "pino": "^9.9.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
